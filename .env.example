# === Client env (.env.local) — read by the Expo app at build time ===

# Written automatically by `npx convex dev` on first run:
CONVEX_DEPLOYMENT=dev:your-deployment-name
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Add this one MANUALLY — same host as EXPO_PUBLIC_CONVEX_URL but `.site`
# instead of `.cloud`. It's the Better Auth baseURL the mobile client calls.
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# === Convex deployment env — set with `npx convex env set <KEY> <VALUE>`,
# NOT placed in this file. These live server-side in the Convex deployment. ===
#   BETTER_AUTH_SECRET   -> openssl rand -base64 32
#   SITE_URL             -> the same https://your-deployment.convex.site URL
