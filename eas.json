{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://opulent-pheasant-365.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://opulent-pheasant-365.convex.site",
        "EXPO_PUBLIC_GOOGLE_AUTH": "true"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CONVEX_URL": "https://opulent-pheasant-365.convex.cloud",
        "EXPO_PUBLIC_CONVEX_SITE_URL": "https://opulent-pheasant-365.convex.site",
        "EXPO_PUBLIC_GOOGLE_AUTH": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
