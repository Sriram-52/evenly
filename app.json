{
  "expo": {
    "name": "Evenly",
    "slug": "evenly",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "evenly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "dev.codebyram.evenly",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.codebyram.evenly",
      "adaptiveIcon": {
        "backgroundColor": "#5B5BD6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5B5BD6",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-contacts",
        {
          "contactsPermission": "Evenly uses your contacts to quickly add roommates to split bills with."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Evenly uses your photos to scan receipts you've saved.",
          "cameraPermission": "Evenly uses your camera to scan grocery receipts.",
          "microphonePermission": false
        }
      ],
      "./plugins/with-blocked-permissions.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d95baeb5-8843-4361-8e3b-7291c0cd78d0"
      }
    },
    "owner": "sriram52",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d95baeb5-8843-4361-8e3b-7291c0cd78d0"
    }
  }
}
