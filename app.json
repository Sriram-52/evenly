{
  "expo": {
    "name": "evenly",
    "slug": "evenly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "evenly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "dev.codebyram.evenly"
    },
    "android": {
      "package": "dev.codebyram.evenly",
      "adaptiveIcon": {
        "backgroundColor": "#5B5BD6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5B5BD6",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-contacts",
        {
          "contactsPermission": "Evenly uses your contacts to quickly add roommates to split bills with."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Evenly uses your photos to scan receipts you've saved.",
          "cameraPermission": "Evenly uses your camera to scan grocery receipts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d95baeb5-8843-4361-8e3b-7291c0cd78d0"
      }
    },
    "owner": "sriram52"
  }
}
